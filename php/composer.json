{
    "name": "movabletype/movabletype",
    "scripts": {
        "post-update-cmd": [
            "git status --short | grep -q 'vendor/adodb/' && git apply patches/adodb5.diff || echo \"adodb5 patch wasnt applied\""
        ]
    },
    "require": {
        "adodb/adodb-php": "5.22.11",
        "smarty/smarty": "4.5.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5.22",
        "phpstan/phpstan": "^1.11",
        "phpstan/phpstan-phpunit": "^1.3"
    }
}
