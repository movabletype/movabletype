<mtapp:statusmsg
   id="system_msg"
   hidden="1"
   class="success">
</mtapp:statusmsg>

<mt:var name="pager" value="$hide_pager" default="0">
<div id="selector-rev" class="selector listing">
<mtapp:listing
   hide_pager="$pager"
   listing_class="mb-3"
   show_actions="$show_actions"
   target="_self"
   empty_message="<__trans phrase="No revisions could be found.">">
<mt:if name="__first__">
  <mt:setvarblock name="table_header">
    <tr>
      <th class="head datetime"><span class="col-label"><__trans phrase="_REVISION_DATE_"></span></th>
      <th class="head note primary"><span class="col-label"><__trans phrase="Note"></span></th>
    <mt:if name="object_type" like="(entry|page|content_data)">
      <th class="head status"><span class="col-label"><__trans phrase="Status"></span></th>
    </mt:if>
      <th class="head created-by d-none d-md-table-cell"><span class="col-label"><__trans phrase="Saved By"></span></th>
    <mt:loop name="more_column_headers">
      <mt:var name="__value__">
    </mt:loop>
    </tr>
  </mt:setvarblock>
  <thead>
    <mt:var name="table_header">
  </thead>
  <tbody>
</mt:if>
    <tr class="<mt:if name="__odd__">odd<mt:else>even</mt:if><mt:if name="is_current"> current-revision highlight mt-table__highlight--current</mt:if>">
      <td class="datetime"><span class="revision-datetime">
        <mt:if name="is_broken">
          <mt:date ts="$created_on" format="%Y-%m-%d %H:%M:%S">
        <mt:else>
          <a class="revision-number" href="javascript:void(0);" onclick="javascript:<$mt:var name="rev_js"$>;"><mt:date ts="$created_on" format="%Y-%m-%d %H:%M:%S"></a>
        </mt:if>
      </span></td>
      <td class="note">
        <mt:if name="is_broken">
          <span class="revision-note"><__trans phrase="*Deleted due to data breakage*">
        <mt:else>
          <span id="revision-note-<mt:var name="rev_number">" class="revision-note" data-rev-number="<mt:var name="rev_number">">
          <mt:if name="description">
            <mt:var name="description" escape="html">
          </mt:if>
          </span>
          <button
            type="button"
            id="revision-edit-<mt:var name="rev_number">"
            class="btn btn-default btn-sm revision-edit-btn"
            data-rev-number="<mt:var name="rev_number">"
            style=" padding: 2px 4px; margin-left: 4px; line-height: 0; text-box-trim: trim-both; position: relative; top: -1px;">
            <svg role="img" class="mt-icon mt-icon--sm">
                <title><__trans phrase="edit"></title>
                <use xlink:href="<mt:var name="static_uri">images/sprite.svg#ic_edit"></use>
            </svg><__trans phrase="edit">
          </button>
        </mt:if>
      </td>
    <mt:if name="object_type" like="(entry|page|content_data)">
      <td class="status">
      <mt:if name="rev_status" eq="1">
        <span class="icon-left-wide icon-draft"><__trans phrase="Draft"></span>
      <mt:else name="rev_status" eq="3">
        <span class="icon-left-wide icon-warning"><__trans phrase="Review"></span>
      <mt:else name="rev_status" eq="4">
        <span class="icon-left-wide icon-future"><__trans phrase="Scheduled"></span>
      <mt:else name="rev_status" eq="2">
        <span class="icon-left-wide icon-success"><__trans phrase="Published"></span>
      <mt:else name="rev_status" eq="5">
        <span class="icon-left-wide icon-spam"><__trans phrase="Spam"></span>
      <mt:else name="rev_status" eq="6">
        <span class="icon-left-wide icon-unpublish"><__trans phrase="Unpublished (End)"></span>
      </mt:if>
      </td>
    </mt:if>
      <td class="created-by d-none d-md-table-cell"><span class="revision-by"><mt:var name="created_by" escape="html"></span></td>
    <mt:loop name="more_columns">
      <mt:var name="__value__">
    </mt:loop>
    </tr>
<mt:if name="__last__">
  </tbody>
</mt:if>
</mtapp:listing>

<div class="row">
  <div class="col-auto mx-auto">
    <mt:include name="include/pagination.tmpl">
  </div>
</div>

</div>

<script
  id="revision-update-script"
  data-object-id="<mt:var name="object_id" encode_html="1">"
  data-object-type="<mt:var name="object_type" encode_html="1">"
  data-magic-token="<mt:var name="magic_token" encode_html="1">"
  data-message-cancel="<__trans phrase="Cancel" escape="html">"
  data-message-update="<__trans phrase="Update" escape="html">"
  data-message-saved="<__trans phrase="This revision note has been saved.">"
  data-message-failed="<__trans phrase="Failed to save" escape="html">"
>
jQuery(function($) {
  const $status = jQuery('#system_msg');

  jQuery('.revision-edit-btn')
    .on('click', function (e) {
      e.stopPropagation();

      const $btn  = jQuery(this);
      const num   = $btn.data('revNumber');
      const $el   = jQuery('#revision-note-' + num);
      const script = jQuery('#revision-update-script');

      if ($btn.data('editing'))
        return;
      $btn.data('editing', true).hide();

      $status.hide();

      let originalText = $el.contents().filter(function () {
        return this.nodeType == Node.TEXT_NODE;
      }).text().trim();

      let $editor = $btn.next('.note-editor');
      if (!$editor.length) {
        $editor = jQuery('<span class="note-editor"></span>');
        $editor.css('display', 'flex').css('flex-wrap', 'wrap').css('gap', '4px');
        $el.text('');
        $btn.after($editor);
      }
      const $input     = jQuery('<input type="text" class="form-control form-control-sm">').val(originalText);
      const $updateBtn = jQuery('<button type="button" class="btn btn-sm btn-primary">' + script.data('messageUpdate') + '</button>');
      const $cancelBtn = jQuery('<button type="button" class="btn btn-sm btn-secondary">' + script.data('messageCancel') + '</button>');

      $editor.append($input, $updateBtn, $cancelBtn);
      $input.trigger('focus');

      const finishEditing = function (newText, message, result) {
        $editor.remove();
        $el.text(newText);
        $btn.data('editing', false).show();
        if ( message && result ) {
          const $closeBtn = jQuery('<button class="btn-close" aria-label="Close"><span aria-hidden="true">×</span></button>');
          $closeBtn.on('click', function (event) {
            event.stopPropagation();
            $status.hide();
          });
          $status.removeClass('alert-success')
            .removeClass('alert-danger').addClass('alert-' + result)
            .text(message).append($closeBtn).show();
        }
      };

      $updateBtn.on('click', function(e) {
        e.preventDefault();
        let newText = $input.val();

        if ( newText == originalText ) {
          finishEditing(newText);
          return;
        }

        $updateBtn.hide();
        $cancelBtn.hide();

        jQuery.ajax({
          type: 'POST',
          contentType: 'application/x-www-form-urlencoded; charset=utf-8',
          url: ScriptURI,
          dataType: 'json',
          data: {
            __mode: 'js_save_rev',
            _type: script.data('objectTtpe'),
            id: script.data('objectId'),
            r: num,
            'revision-note': newText,
            magic_token: script.data('magicToken')
          },
          success: function(data) {
            finishEditing(newText, script.data('messageSaved'), 'success');
          },
          error: function(xhr, status) {
            finishEditing(originalText, script.data('messageFailed'), 'danger');
          }
        });
        return false;
      });

      $cancelBtn.on('click', function() {
        finishEditing(originalText);
      });

    });
});
</script>