<mt:var name="pager" value="$hide_pager" default="0">
<div id="selector-rev" class="selector listing">
<mtapp:listing
   hide_pager="$pager"
   listing_class="mb-3"
   show_actions="$show_actions"
   target="_self"
   empty_message="<__trans phrase="No revisions could be found.">">
<mt:if name="__first__">
  <mt:setvarblock name="table_header">
    <tr>
      <th class="head datetime"><span class="col-label"><__trans phrase="_REVISION_DATE_"></span></th>
      <th class="head note primary"><span class="col-label"><__trans phrase="Note"> (<__trans phrase="Click to edit note">)</span></th>
    <mt:if name="object_type" like="(entry|page|content_data)">
      <th class="head status"><span class="col-label"><__trans phrase="Status"></span></th>
    </mt:if>
      <th class="head created-by d-none d-md-table-cell"><span class="col-label"><__trans phrase="Saved By"></span></th>
    <mt:loop name="more_column_headers">
      <mt:var name="__value__">
    </mt:loop>
    </tr>
  </mt:setvarblock>
  <thead>
    <mt:var name="table_header">
  </thead>
  <tbody>
</mt:if>
    <tr class="<mt:if name="__odd__">odd<mt:else>even</mt:if><mt:if name="is_current"> current-revision highlight mt-table__highlight--current</mt:if>">
      <td class="datetime"><span class="revision-datetime">
        <mt:if name="is_broken">
          <mt:date ts="$created_on" format="%Y-%m-%d %H:%M:%S">
        <mt:else>
          <a class="revision-number" href="javascript:void(0);" onclick="javascript:<$mt:var name="rev_js"$>;"><mt:date ts="$created_on" format="%Y-%m-%d %H:%M:%S"></a>
        </mt:if>
      </span></td>
      <td class="note">
        <mt:if name="is_broken">
          <span class="revision-note"><__trans phrase="*Deleted due to data breakage*">
        <mt:else>
          <span class="revision-note" data-rev-number="<mt:var name="rev_number">">
          <mt:if name="description">
            <mt:var name="description" escape="html">
          </mt:if><button
            type="button"
            id="revision-edit-<mt:var name="rev_number">"
            class="btn btn-default btn-sm edit-btn"
            style="margin-left: 4px;">
            <svg role="img" class="mt-icon mt-icon--sm">
                <title><__trans phrase="edit"></title><use xlink:href="<mt:var name="static_uri">images/sprite.svg#ic_edit"></use>
            </svg>
          </button>
        </mt:if>
      </span></td>
    <mt:if name="object_type" like="(entry|page|content_data)">
      <td class="status">
      <mt:if name="rev_status" eq="1">
        <span class="icon-left-wide icon-draft"><__trans phrase="Draft"></span>
      <mt:else name="rev_status" eq="3">
        <span class="icon-left-wide icon-warning"><__trans phrase="Review"></span>
      <mt:else name="rev_status" eq="4">
        <span class="icon-left-wide icon-future"><__trans phrase="Scheduled"></span>
      <mt:else name="rev_status" eq="2">
        <span class="icon-left-wide icon-success"><__trans phrase="Published"></span>
      <mt:else name="rev_status" eq="5">
        <span class="icon-left-wide icon-spam"><__trans phrase="Spam"></span>
      <mt:else name="rev_status" eq="6">
        <span class="icon-left-wide icon-unpublish"><__trans phrase="Unpublished (End)"></span>
      </mt:if>
      </td>
    </mt:if>
      <td class="created-by d-none d-md-table-cell"><span class="revision-by"><mt:var name="created_by" escape="html"></span></td>
    <mt:loop name="more_columns">
      <mt:var name="__value__">
    </mt:loop>
    </tr>
<mt:if name="__last__">
  </tbody>
</mt:if>
</mtapp:listing>

<div class="row">
  <div class="col-auto mx-auto">
    <mt:include name="include/pagination.tmpl">
  </div>
</div>

</div>

<script>
jQuery(function($) {

  jQuery('.revision-note')
    .on('click', function (e) {
      e.stopPropagation();

      const $el   = jQuery(this);
      const num   = $el.data('revNumber');
      const token = '<mt:var name="magic_token">';
      const $btn  = jQuery('#revision-edit-' + num);

      if ($el.data('editing'))
        return;
      $el.data('editing', true);

      let $status = $el.next('.save-status');
      if (!$status.length) {
        $status = jQuery('<span class="save-status">').css({ marginLeft: '8px', fontSize: '0.9em' });
        $el.after($status);
      }

      let originalText = $el.contents().filter(function () {
        return this.nodeType == Node.TEXT_NODE;
      }).text().trim();

      let $editor = $el.next('.note-editor');
      if (!$editor.length) {
        $editor = jQuery('<span class="note-editor"></span>');
        $editor.css('display', 'inline-flex').css('white-space', 'nowrap').css('gap', '4px');
        $el.text('');
        $el.after($editor);
      }
      const $input     = jQuery('<input type="text" class="form-control form-control-sm">').val(originalText);
      const $updateBtn = jQuery('<button type="button" class="btn btn-sm btn-primary">更新</button>');
      const $cancelBtn = jQuery('<button type="button" class="btn btn-sm btn-secondary">キャンセル</button>');

      $editor.append($input, $updateBtn, $cancelBtn);
      $input.focus();

      const finishEditing = function (newText) {
        $editor.remove();
        $el.text(newText);
        $el.append($btn);
        $el.data('editing', false);
      };

      $updateBtn.on('click', function(e) {
        e.preventDefault();
        let newText = $input.val();

        if ( newText == originalText ) {
          finishEditing(newText);
          return;
        }

        $editor.remove();
        $status.text('<__trans phrase="Saving...">').removeClass('alert-success alert-danger').css('color', 'gray');

        jQuery.ajax({
          type: 'POST',
          contentType: 'application/x-www-form-urlencoded; charset=utf-8',
          url: '<mt:var name="script_url">',
          dataType: 'json',
          data: {
            __mode: 'js_save_rev',
            _type: '<mt:var name="object_type">',
            id: <mt:var name="object_id">,
            r: num,
            'revision-note': newText,
            magic_token: '<mt:var name="magic_token">'
          },
          success: function(data) {
            finishEditing(newText);
            $status.text('');
          },
          error: function(xhr, status) {
            finishEditing(originalText);
            $status.text('<__trans phrase="Failed to save">').css('color', 'red');
            $status.fadeOut(3000, function() {
                jQuery(this).text('').show();
            });
          }
        });
        return false;
      });

      $cancelBtn.on('click', function() {
        $editor.remove();
        finishEditing(originalText);
      });

    });
});
</script>