<mtapp:widget
  class="site-stats-widget"
  label="<__trans phrase="Site Stats">"
  can_close="1">
<div class="row up-column">
  <div id="statistics_settings_link" class="col-12 text-end">
    <a href="<mt:var name="mt_url">?__mode=cfg_web_services&amp;blog_id=<mt:var name="blog_id">"><__trans phrase="Statistics Settings"></a>
  </div>
</div>
<div class="row down-column">
  <div class="col-12 down-column-contents">
    <canvas id="graph" style="width: 99%; height: 200px;"></canvas>
  </div>
</div>
<div class="mt-5 stats_provider text-end text-muted">Provider:<mt:var name="stats_provider" escape="html"></div>
</mtapp:widget>

<mt:setvarblock name="js_include" append="1">
<mtapp:script path="chartjs/chart.umd.min.js">
<script type="text/javascript">
/* <![CDATA[ */
  jQuery(function() {
    var chartColors = [
      '#6AAC2B',
      '#FFBE00',
      '#CF6DD3',
      '#8F2CFF',
      '#2D85FF',
      '#5584D4',
      '#5ED2B8',
      '#9CCF41',
      '#F87085',
      '#2C8087',
      '#8EEC6A',
      '#FFE700',
      '#FF5E19',
      '#FF4040',
      '#976BD6',
      '#503D99',
      '#395595'
    ];

    jQuery('#statistics_settings_link').hide();

    get_graph_data('<mt:var name="stat_url">', true);

    function get_graph_data(stat_url, retry) {
      jQuery.ajax(stat_url, {
        dataType: 'jsonp',
        jsonpCallback: 'widget_site_stats_draw_graph',
        error: function(xhr) {
            if (retry && xhr.status === 404) {
              jQuery('select#select_blog_id').triggerHandler('change');
            }
          },
        success: function(data) {
            widget_site_stats_draw(data);
          }
      });
    }

    function addComma (str) {
      var num = new String(str).replace(/,/g, "");
      while(num != (num = num.replace(/^(-?\d+)(\d{3})/, "$1,$2")));
      return num;
    }

    function widget_site_stats_draw(data) {
      jQuery('.site-stats-widget .down-column').css('height', '');

      if (data.error) {
        jQuery('#graph')
          .append(jQuery('<div class="msg msg-error"/>').text(data.error));
        jQuery('.site-stats-widget .down-column').css('height', 'auto');
      }

      const labels = data.graph_data.map((item) => item.x);
      const keyCount = data.reg_keys.length;
      let datasets = [];
      for (let i = 0; i < keyCount; i++) {
        const label = data.reg_keys[i];
        const prop = (i == 0) ? 'y' : 'y' + i;
        const items = data.graph_data.map((item) => item[prop] || 0);
        let colorSubscript = i;
        if ( i > 16 ) {
          const number = parseInt(i/17);
          colorSubscript = i - ( 17 * number );
        }
        const color = chartColors[colorSubscript];
        datasets[i] = {
          label: label,
          data: items,
          borderColor: color,
          backgroundColor: color,
        };
      }

      Chart.defaults.font.size = 14;
      Chart.defaults.elements.point.hoverRadius = 5;
      const ctx = document.getElementById('graph');
      new Chart(ctx, {
        type: 'line',
        data: {
          labels: labels,
          datasets: datasets,
        },
        options: {
          maintainAspectRatio: false,
          animation: false,
          interaction: {
            intersect: false,
            mode: 'index',
          },
          scales: {
            x: {
              ticks: {
                padding: 13,
                maxRotation: 0,
                autoSkipPadding: 24,
                color: '#999',
                font: {
                  size: 13,
                },
              },
              grid: {
                tickLength: -8,
                drawOnChartArea: false,
              },
            },
            y: {
              beginAtZero: true,
              ticks: {
                display: false,
                maxTicksLimit: 5,
              },
              grid: {
                drawTicks: false,
              },
            },
          },
          layout: {
            padding: {
              left: 32,
              right: 32,
            },
          },
          plugins: {
            legend: {
                labels: {
                  usePointStyle: true,
                  boxHeight: 5,
                  boxWidth: 5,
                },
            },
            tooltip: {
              usePointStyle: true,
              boxHeight: 5,
              boxWidth: 5,
              boxPadding: 4,
              padding: 12,
              backgroundColor: 'rgba(255, 255, 255, 0.9)',
              borderColor: 'rgba(0, 0, 0, 0.1)',
              borderWidth: 2,
              titleColor: '#666',
              bodyColor: '#666',
              footerColor: '#666',
              multiKeyBackground: '#666',
            },
          },
        }
      });
      if (data.can_edit_config) {
        jQuery('#statistics_settings_link').show();
      }
    }
  });

  /* ]]> */
</script>
</mt:setvarblock>
