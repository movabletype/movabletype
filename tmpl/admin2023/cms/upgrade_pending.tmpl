<mt:if name="upgrade_pending">
<mt:setvarblock name="page_title"><__trans phrase="Upgrade Pending"></mt:setvarblock>
<mt:else>
<mt:setvarblock name="page_title"><__trans phrase="Upgrade Check"></mt:setvarblock>
</mt:if>

<mt:setvar name="complete" value="1">

<mt:setvarblock name="page_content">
<div class="upgrade">

<mt:if name="upgrade_pending">
    <p><__trans phrase="A new version of Movable Type has been installed. Please wait until an administrator completes the upgrade."></p>

    <form method="post" action="<mt:var name="script_url">">
      <input type="hidden" name="magic_token" value="<mt:var name="magic_token">" />
      <input type="hidden" name="__mode" value="logout" />
      <div class="actions-bar text-end">
        <button
           type="submit"
           accesskey="s"
           title="<__trans phrase="sign out"> (s)"
           class="signout action primary button btn btn-primary">
          <__trans phrase="sign out">
        </button>
      </div>
    </form>

<mt:else>
  <mt:if name="mt_version_incremented">
  <p><__trans phrase="Congratulations, you have successfully upgraded to Movable Type [_1]." params="<mt:var name="mt_version">"></p>

  <form method="get" action="<mt:var name="mt_url">">
    <div class="actions-bar text-end">
      <button
         type="submit"
         accesskey="s"
         title="<__trans phrase="Return to Movable Type"> (s)"
         class="action primary button btn btn-primary">
        <__trans phrase="Return to Movable Type">
      </button>
    </div>
  </form>

  <mt:else>
  <p><__trans phrase="Your Movable Type installation is already up to date."></p>

  <form method="get" action="<mt:var name="mt_url">">
    <div class="actions-bar text-end">
      <button
         type="submit"
         accesskey="s"
         title="<__trans phrase="Return to Movable Type"> (s)"
         class="action primary button btn btn-primary">
        <__trans phrase="Return to Movable Type">
      </button>
    </div>
  </form>
  </mt:if>
</mt:if>
</div>
</mt:setvarblock>

<mt:setvarblock name="js_include" append="1">
<script>
/* <![CDATA[ */
function dismiss(id) {
    jQuery('#'+id).hide();
}

function show(id) {
    jQuery('#'+id).show();
}
/* ]]> */
</script>
</mt:setvarblock>

<mt:include name="layout/chromeless.tmpl">
<mt:var name="layout">

